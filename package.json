{
  "name": "haravan-mcp",
  "version": "0.1.0",
  "description": "Haravan E-commerce OpenAPI MCP Server - Connect AI assistants to Haravan stores",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "HaravanMCP",
  "license": "MIT",
  "bin": {
    "haravan-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "ts-node src/cli.ts",
    "dev:cli": "ts-node src/cli.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "haravan",
    "mcp",
    "open-api",
    "ecommerce",
    "ai",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.8.4",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "open": "^8.4.2",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.4.5",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
